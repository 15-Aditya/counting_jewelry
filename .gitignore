# ============================================================
# LARGE DATA FOLDERS - Exclude from git
# ============================================================

# Roboflow downloaded images and annotations (2-10 GB)
data/coco_dataset/

# YOLO format images (duplicate, ~2-10 GB)
data/dataset/images/
data/dataset/labels/

# Test inference results (not needed in repo)
data/test_results/

# Virtual environment
data/venv/

# Downloaded base YOLO models
*.pt
!**/weights/*.pt
!**/models/*.pt

# ============================================================
# IMPORTANT FILES - Keep these (DO NOT ignore)
# ============================================================
# The following are explicitly NOT ignored:
# - data/runs/train/weights/*.pt (all epoch weights)
# - data/runs/train/*.csv (results.csv)
# - data/runs/train/*.png (training plots)
# - data/runs/train/args.yaml
# - data/dataset/data.yaml (class names)
# - data/models/*.pt (timestamped backups)

