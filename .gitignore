# ============================================================
# LARGE DATA FOLDERS - Exclude from git
# ============================================================

# Roboflow downloaded COCO dataset images and annotations (2-10 GB)
data/coco_dataset/

# YOLO format dataset images and labels (2-10 GB)
data/dataset/images/
data/dataset/labels/

# Training runs folder - contains all epoch weights and training outputs (5-10 GB)
data/runs/

# Test inference results
data/test_results/

# Virtual environment
data/venv/

# Downloaded base YOLO models (100+ MB each)
*.pt

# BUT keep timestamped model backups in models directory
!data/models/*.pt

# ============================================================
# IMPORTANT FILES - Keep these (committed to git)
# ============================================================
# - data/dataset/data.yaml (class names and dataset config)
# - data/models/*.pt (timestamped best/last model backups)
# - All Python scripts
# - requirements.txt
# - README.md

